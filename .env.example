# OpenClaw Jay - Infinee Production
# Copy to .env and fill in values

# Gateway auth
OPENCLAW_GATEWAY_TOKEN=<openssl rand -hex 32>

# Gateway config
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Paths (persistent host volumes)
OPENCLAW_CONFIG_DIR=/opt/openclaw-jay/data/.openclaw
OPENCLAW_WORKSPACE_DIR=/opt/openclaw-jay/data/.openclaw/workspace

# Keyring
GOG_KEYRING_PASSWORD=<openssl rand -hex 32>

# Timezone
OPENCLAW_TZ=Europe/Bratislava

# Image
OPENCLAW_IMAGE=openclaw:local

# --- Project Databases (readonly) ---
VIRALSKY_DB_URL=postgresql://jay_readonly:PASSWORD@HOST:PORT/viralsky
SKYSNAIL_DB_URL=postgresql://jay_readonly:PASSWORD@172.17.0.1:5432/DATABASE
ANDERRO_DB_URL=postgresql://jay_readonly:PASSWORD@HOST:PORT/anderro
FOODIENT_DB_URL=postgresql://jay_readonly:PASSWORD@HOST:PORT/foodient

# --- WordPress ---
AITRENDZ_WP_APP_PASS=<application password from wp-admin>
